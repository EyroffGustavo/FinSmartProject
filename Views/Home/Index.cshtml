@{
    ViewData["Title"] = "FinSmart";
}

<div class="fs-shell">
    <aside class="fs-sidebar">
        <div class="fs-brand">
            <div class="fs-logo">F</div>
            <div>
                <strong>FinSmart</strong>
                <span>Financeiro Inteligente</span>
            </div>
        </div>

        <nav class="fs-nav">
            <button class="nav-item active" data-page="dashboard">Overview</button>
            <button class="nav-item" data-page="receitas">Receitas</button>
            <button class="nav-item" data-page="despesas">Despesas</button>
            <button class="nav-item" data-page="dividas">Dívidas</button>
            <button class="nav-item" data-page="metas">Metas</button>
            <button class="nav-item" data-page="relatorios">Relatórios</button>
            <button class="nav-item" data-page="calendario">Calendário</button>
            <button class="nav-item" data-page="investimentos">Investimentos</button>
            <button class="nav-item" data-page="futuro">Planejamento Futuro</button>
            <button class="nav-item" data-page="planejador">Planejador</button>
            <button class="nav-item" data-page="importacao">Importar Extrato</button>
        </nav>

        <div class="fs-score-card">
            <span>Saúde financeira</span>
            <strong id="scoreSidebar">0/100</strong>
            <div class="mini-progress">
                <span id="scoreBar"></span>
            </div>
        </div>
    </aside>

    <main class="fs-main">
        <header class="fs-topbar">
            <div>
                <span class="fs-kicker">Dashboard pessoal</span>
                <h1 id="pageTitle">Overview financeiro</h1>
                <p>Controle suas finanças com clareza, metas e inteligência.</p>
            </div>

            <button class="danger-soft" onclick="limparTudo()">Limpar dados</button>
        </header>

        <section id="dashboard" class="page active">
            <div class="fs-hero">
                <div>
                    <span>Saldo disponível</span>
                    <h2 id="saldoAtual">R$ 0,00</h2>
                    <p id="saldoStatus">Cadastre receitas e despesas para iniciar.</p>
                </div>

                <div class="score-ring">
                    <strong id="scoreHero">0</strong>
                    <span>score</span>
                </div>
            </div>

            <div class="fs-metrics">
                <div class="metric income">
                    <span>Receitas</span>
                    <strong id="totalReceitas">R$ 0,00</strong>
                    <small>Entradas registradas</small>
                </div>

                <div class="metric expense">
                    <span>Despesas</span>
                    <strong id="totalDespesas">R$ 0,00</strong>
                    <small>Saídas registradas</small>
                </div>

                <div class="metric debt">
                    <span>Dívidas</span>
                    <strong id="totalDividas">R$ 0,00</strong>
                    <small>Compromissos ativos</small>
                </div>

                <div class="metric goal">
                    <span>Metas</span>
                    <strong id="totalMetas">0</strong>
                    <small>Objetivos cadastrados</small>
                </div>
            </div>

            <div class="fs-grid">
                <div class="panel wide">
                    <div class="panel-title">
                        <h3>Últimas movimentações</h3>
                        <span>Histórico recente</span>
                    </div>
                    <div id="ultimasMovimentacoes"></div>
                </div>

                <div class="panel">
                    <div class="panel-title">
                        <h3>Assistente financeiro</h3>
                        <span>Análise automática</span>
                    </div>
                    <p id="resumoInteligente"></p>
                </div>
            </div>
        </section>

        <section id="receitas" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Nova receita</h3>
                    <span>Cadastre suas entradas mensais</span>
                </div>

                <form id="formReceita" class="smart-form">
                    <input placeholder="Descrição" id="receitaDescricao" required />
                    <input placeholder="Categoria" id="receitaCategoria" required />
                    <input placeholder="Valor" id="receitaValor" type="number" step="0.01" required />
                    <input id="receitaData" type="date" required />
                    <button>Adicionar</button>
                </form>

                <div id="listaReceitas"></div>
            </div>
        </section>

        <section id="despesas" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Nova despesa</h3>
                    <span>Controle suas saídas</span>
                </div>

                <form id="formDespesa" class="smart-form">
                    <input placeholder="Descrição" id="despesaDescricao" required />
                    <input placeholder="Categoria" id="despesaCategoria" required />
                    <input placeholder="Valor" id="despesaValor" type="number" step="0.01" required />
                    <input id="despesaData" type="date" required />
                    <button>Adicionar</button>
                </form>

                <div id="listaDespesas"></div>
            </div>
        </section>

        <section id="dividas" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Nova dívida</h3>
                    <span>Planeje a quitação com prazo definido</span>
                </div>

                <form id="formDivida" class="smart-form three">
                    <input placeholder="Nome da dívida" id="dividaNome" required />
                    <input placeholder="Valor total" id="dividaValor" type="number" step="0.01" required />
                    <input placeholder="Prazo em meses" id="dividaPrazo" type="number" required />
                    <button>Adicionar</button>
                </form>

                <div id="listaDividas"></div>
            </div>
        </section>

        <section id="metas" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Nova meta</h3>
                    <span>Acompanhe seus objetivos</span>
                </div>

                <form id="formMeta" class="smart-form three">
                    <input placeholder="Nome da meta" id="metaNome" required />
                    <input placeholder="Valor objetivo" id="metaObjetivo" type="number" step="0.01" required />
                    <input placeholder="Valor atual" id="metaAtual" type="number" step="0.01" required />
                    <button>Adicionar</button>
                </form>

                <div id="listaMetas"></div>
            </div>
        </section>

        <section id="relatorios" class="page">
            <div class="fs-grid">
                <div class="panel">
                    <div class="panel-title">
                        <h3>Receitas x Despesas</h3>
                        <span>Comparativo financeiro</span>
                    </div>
                    <canvas id="fluxoChart"></canvas>
                </div>

                <div class="panel">
                    <div class="panel-title">
                        <h3>Gastos por categoria</h3>
                        <span>Classificação automática</span>
                    </div>
                    <canvas id="categoriaChart"></canvas>
                </div>
            </div>

            <div class="panel mt-panel">
                <div class="panel-title">
                    <h3>Reserva de emergência</h3>
                    <span>Baseada em 6 meses de despesas médias</span>
                </div>

                <h2 id="reservaIdeal">R$ 0,00</h2>

                <div class="progress">
                    <div id="reservaBarra" class="progress-bar"></div>
                </div>

                <p id="reservaTexto"></p>
            </div>
        </section>

        <section id="calendario" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Calendário financeiro</h3>
                    <span>Entradas, saídas e parcelas previstas</span>
                </div>

                <div id="calendarioFinanceiro"></div>
            </div>
        </section>

        <section id="investimentos" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Carteira de investimentos</h3>
                    <span>Controle simples do patrimônio investido</span>
                </div>

                <form id="formInvestimento" class="smart-form three">
                    <input id="investNome" placeholder="Nome" required />
                    <select id="investTipo">
                        <option>CDB</option>
                        <option>Tesouro</option>
                        <option>Ações</option>
                        <option>Fundos</option>
                        <option>Cripto</option>
                        <option>Outro</option>
                    </select>
                    <input id="investValor" type="number" step="0.01" placeholder="Valor" required />
                    <button>Adicionar</button>
                </form>

                <h2 id="totalInvestido">R$ 0,00</h2>
                <div id="listaInvestimentos"></div>
            </div>
        </section>

        <section id="futuro" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Planejamento futuro</h3>
                    <span>Controle entradas fixas, parcelas e compromissos futuros</span>
                </div>

                <form id="formFuturo" class="smart-form">
                    <input placeholder="Descrição" id="futuroDescricao" required />
                    <select id="futuroTipo" required>
                        <option value="entrada">Entrada</option>
                        <option value="saida">Saída / Parcela</option>
                    </select>
                    <input placeholder="Valor mensal" id="futuroValor" type="number" step="0.01" required />
                    <input placeholder="Total de meses" id="futuroMeses" type="number" required />
                    <button>Adicionar</button>
                </form>

                <div class="future-summary">
                    <div>
                        <span>Entradas previstas</span>
                        <strong id="futuroEntradas">R$ 0,00</strong>
                    </div>
                    <div>
                        <span>Saídas previstas</span>
                        <strong id="futuroSaidas">R$ 0,00</strong>
                    </div>
                    <div>
                        <span>Saldo futuro</span>
                        <strong id="futuroSaldo">R$ 0,00</strong>
                    </div>
                </div>

                <div id="listaFuturo"></div>
            </div>
        </section>

        <section id="planejador" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Planejador inteligente</h3>
                    <span>Simule metas, dívidas e prazos</span>
                </div>

                <form id="formPlanejador" class="smart-form">
                    <input placeholder="Renda mensal" id="planRenda" type="number" step="0.01" required />
                    <input placeholder="Gastos fixos" id="planFixos" type="number" step="0.01" required />
                    <input placeholder="Gastos variáveis" id="planVariaveis" type="number" step="0.01" required />
                    <input placeholder="Valor da dívida/meta" id="planObjetivo" type="number" step="0.01" required />
                    <input placeholder="Prazo em meses" id="planPrazo" type="number" required />
                    <button>Calcular</button>
                </form>

                <div id="resultadoPlanejador" class="planner-result"></div>
            </div>
        </section>

        <section id="importacao" class="page">
            <div class="panel">
                <div class="panel-title">
                    <h3>Importar extrato</h3>
                    <span>Envie arquivos OFX, CSV ou PDF para classificação automática</span>
                </div>

                <form id="formImportacao" class="upload-box">
                    <input type="file" id="arquivoExtrato" accept=".ofx,.csv,.pdf" required />
                    <button type="submit">Importar Arquivo</button>
                </form>

                <div id="resultadoImportacao" class="planner-result">
                    Selecione um arquivo para iniciar a importação inteligente.
                </div>
            </div>
        </section>
    </main>
</div>
